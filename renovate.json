{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranches": ["staging"],
  "timezone": "Europe/Berlin",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchPackagePrefixes": ["androidx."],
      "groupName": "androidx"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep the Renovate runner image in renovate.yml up to date",
      "fileMatch": ["^\\.github/workflows/renovate\\.yml$"],
      "matchStrings": ["image:\\s*renovate/renovate:(?<currentValue>\\S+)"],
      "depNameTemplate": "renovate/renovate",
      "datasourceTemplate": "docker"
    }
  ]
}
